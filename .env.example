# AccessAI Environment Configuration
# Copy this file to .env and fill in your values

# ===== Database =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password_here
POSTGRES_DB=accessai
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_password_here@localhost:5432/accessai

# ===== AI Configuration =====
# Get your free API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# ===== Security =====
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars

# ===== Scan Settings =====
MAX_PAGES=10
SCAN_TIMEOUT=30
WCAG_LEVEL=AA

# ===== Reports =====
REPORTS_DIR=./reports
