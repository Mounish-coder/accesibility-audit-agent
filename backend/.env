# AccessAI Backend Environment
# SQLite database (local dev — no PostgreSQL needed)
DATABASE_URL=sqlite+aiosqlite:///./accessai.db

# Groq AI (optional — leave empty to use mock intelligence data)
# Get your free key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# Security
SECRET_KEY=accessibility-audit-dev-secret-key-change-in-prod

# Scan settings
MAX_PAGES=10
SCAN_TIMEOUT=30
WCAG_LEVEL=AA

# Reports
REPORTS_DIR=./reports
